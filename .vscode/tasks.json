{
  "version": "2.0.0",
  "command": "bun",
  "tasks": [
    {
      "label": "Build All",
      "type": "shell",
      "command": "bun",
      "args": ["run", "build"],
      "group": "build"
    },
    {
      "label": "Build Lib",
      "type": "shell",
      "command": "bun",
      "args": ["run", "build:lib"],
      "group": "build"
    },
    {
      "label": "Build CSS",
      "type": "shell",
      "command": "bun",
      "args": ["run", "build:css"],
      "group": "build"
    },
    {
      "label": "Build Bundles",
      "type": "shell",
      "command": "bun",
      "args": ["run", "build:bundles"],
      "group": "build"
    },
    {
      "label": "Build Vite Plugins",
      "type": "shell",
      "command": "bun",
      "args": ["run", "build:vite"],
      "group": "build"
    },
    {
      "label": "test",
      "type": "shell",
      "group": {
        "kind": "test"
      },
      "args": ["test"]
    },
    {
      "label": "install",
      "type": "shell",
      "group": {
        "kind": "none"
      },
      "args": ["i"]
    }
  ]
}
